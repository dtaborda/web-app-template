# ============================================
# Web App Template - Environment Variables
# ============================================
# Copy this file to .env.local and uncomment the variables you need
# NEVER commit .env.local to version control

# ============================================
# AI Chat Configuration (Optional)
# ============================================
# Required ONLY if you want to use the /chat page
# Get your API key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-openai-api-key-here

# ============================================
# Application Configuration (Optional)
# ============================================
# Environment: development | staging | production
# NEXT_PUBLIC_APP_ENV=development

# Application base URL (for absolute URLs, redirects, etc.)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# NOTES
# ============================================
# 1. Copy this file: cp .env.example .env.local
# 2. Uncomment and fill in the values you need
# 3. Restart dev server after changes: pnpm dev
# 4. For production: set variables in your hosting platform (Vercel, Railway, etc.)
#
# Variable Prefix Rules:
# - NEXT_PUBLIC_* = Available in browser (client-side)
# - No prefix = Server-side only (API keys, secrets)
#
# The template works WITHOUT any environment variables.
# Only add them if you need specific features (like AI chat).
