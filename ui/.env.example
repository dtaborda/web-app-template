# Web App Template - Environment Variables
# Copy this file to .env.local and fill in your actual values
# NEVER commit .env.local to version control

# ============================================
# AI SDK Configuration (Optional)
# ============================================
# Required for chat features (/chat page)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Alternative AI Providers (uncomment to use)
# ANTHROPIC_API_KEY=your-anthropic-api-key
# GOOGLE_GENERATIVE_AI_API_KEY=your-google-api-key
# COHERE_API_KEY=your-cohere-api-key

# ============================================
# Application Configuration
# ============================================
# Environment: development | staging | production
NEXT_PUBLIC_APP_ENV=development

# Application URL (used for absolute URLs, redirects, etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# API Configuration (Optional - for future use)
# ============================================
# Backend API base URL (if you add a backend later)
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# API timeout in milliseconds
# NEXT_PUBLIC_API_TIMEOUT=30000

# ============================================
# Feature Flags (Optional)
# ============================================
# Enable/disable features without code changes
# NEXT_PUBLIC_FEATURE_CHAT=true
# NEXT_PUBLIC_FEATURE_ANALYTICS=false

# ============================================
# Analytics (Optional)
# ============================================
# Google Analytics ID
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# PostHog API Key
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ============================================
# Database (Optional - for future use)
# ============================================
# PostgreSQL connection string
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Supabase (if using Supabase)
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================
# Authentication (Optional - for future use)
# ============================================
# NextAuth secret (generate with: openssl rand -base64 32)
# NEXTAUTH_SECRET=your-generated-secret-here
# NEXTAUTH_URL=http://localhost:3000

# OAuth Providers (if using OAuth)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret

# ============================================
# Email (Optional - for future use)
# ============================================
# Resend API Key (for transactional emails)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# SendGrid API Key (alternative)
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx

# ============================================
# File Storage (Optional - for future use)
# ============================================
# AWS S3 for file uploads
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_S3_BUCKET=your-bucket-name

# Cloudinary (alternative)
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# ============================================
# Monitoring & Error Tracking (Optional)
# ============================================
# Sentry DSN for error tracking
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
# SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ============================================
# Development Tools (Optional)
# ============================================
# Enable debug logging
# DEBUG=true

# Skip TypeScript errors during build (NOT RECOMMENDED)
# SKIP_TYPE_CHECK=false

# ============================================
# NOTES
# ============================================
# 1. Copy this file to .env.local: cp .env.example .env.local
# 2. Fill in your actual values in .env.local
# 3. NEVER commit .env.local to git (it's in .gitignore)
# 4. Use NEXT_PUBLIC_ prefix ONLY for client-side variables
# 5. Keep secrets (API keys, tokens) server-side only (no NEXT_PUBLIC_)
# 6. Restart dev server after changing environment variables
# 7. For production, set these in your hosting platform (Vercel, etc.)
